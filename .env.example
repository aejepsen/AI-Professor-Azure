# =============================================================================
# AI Professor — Variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o .env — apenas este .env.example
# =============================================================================

# --- Anthropic (LLM) ---------------------------------------------------------
ANTHROPIC_API_KEY=change-me-sk-ant-api03-xxxx

# --- Qdrant (vector database) ------------------------------------------------
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=change-me-qdrant-api-key

# --- Azure Entra ID (autenticação) -------------------------------------------
AZURE_TENANT_ID=change-me-tenant-id
AZURE_CLIENT_ID=change-me-client-id

# --- Azure Storage (uploads) -------------------------------------------------
AZURE_STORAGE_ACCOUNT_NAME=change-me-storage-account
AZURE_STORAGE_ACCOUNT_KEY=change-me-storage-key
AZURE_STORAGE_CONTAINER=uploads

# --- AssemblyAI (transcrição de vídeo) ---------------------------------------
ASSEMBLYAI_API_KEY=change-me-assemblyai-key

# --- CORS (opcional — padrão já inclui Azure Static Web App + localhost:4200) -
# Para customizar, forneça uma lista JSON:
# CORS_ORIGINS=["https://sua-app.azurestaticapps.net","http://localhost:4200"]

# --- RAGAS (avaliação de RAG — apenas para testes) ---------------------------
RAGAS_TEST_TOKEN=change-me-ragas-token

# --- Terraform (infra como código) -------------------------------------------
ARM_SUBSCRIPTION_ID=change-me-subscription-id
ARM_TENANT_ID=change-me-tenant-id
ARM_ACCESS_KEY=change-me-storage-account-key-for-terraform-backend

# --- GitHub Container Registry (CI/CD) ---------------------------------------
GHCR_USERNAME=change-me-github-username
GHCR_TOKEN=change-me-ghp-token
